# Domain for SSL certificates
DOMAIN=example.com

# DockerHub
DOCKERHUB_USERNAME=yourusername
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_DB=angularnetbase
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Full connection string for the .NET backend (must match the PostgreSQL values above)
# Quotes are required because the value contains semicolons
CONNECTION_STRING="Host=db;Port=5432;Database=angularnetbase;Username=postgres;Password=CHANGE_ME_strong_password_here"

# JWT Configuration
JWT_SECRET=CHANGE_ME_at_least_32_bytes_long_production_secret_key
JWT_ISSUER=AngularNetBase
JWT_AUDIENCE=AngularNetBase
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# Seed practice content in production (one-time)
SEED_PRACTICE_CONTENT=false

# OpenAI
OPENAI_API_KEY=CHANGE_ME_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_GRADER_MODEL=gpt-5.4-mini
OPENAI_GUIDE_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0.3

# MinIO (S3-compatible) for journal photos
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=journal-photos
MINIO_USE_SSL=false

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_pgadmin_password

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com
